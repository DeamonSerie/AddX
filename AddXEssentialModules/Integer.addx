# =============================================================================
# INTEGER MATH FUNCTIONS
# =============================================================================

def abs(x: int): int
    return -x if x < 0 else x

def min(a: int, b: int): int
    return b if a > b else a

def max(a: int, b: int): int
    return a if a > b else b

def minOf(values: list<int>): int
    result: int = values[0]
    for v in values:
        if v < result:
            result = v
    return result

def maxOf(values: list<int>): int
    result: int = values[0]
    for v in values:
        if v > result:
            result = v
    return result

def clamp(value: int, minVal: int, maxVal: int): int
    if value < minVal:
        return minVal
    if value > maxVal:
        return maxVal
    return value

def sign(x: int): int
    return -1 if x < 0 else (1 if x > 0 else 0)

def isEven(x: int): bool
    return x % 2 == 0

def isOdd(x: int): bool
    return x % 2 != 0

def isPositive(x: int): bool
    return x > 0

def isNegative(x: int): bool
    return x < 0

def isZero(x: int): bool
    return x == 0

def isPowerOfTwo(x: int): bool
    return x > 0 and (x & (x - 1)) == 0

def isPrime(n: int): bool
    if n < 2:
        return False
    if n == 2:
        return True
    if n % 2 == 0:
        return False
    if n < 9:
        return True
    
    r: int = Integer.floorSqrt(n)
    i: int = 3
    
    while i <= r:
        if n % i == 0:
            return False
        i = i + 2
    
    return True

def isPerfectSquare(n: int): bool
    if n < 0:
        return False
    
    root: int = Integer.floorSqrt(n)
    return root * root == n

def isPerfectCube(n: int): bool
    root: int = Integer.round(Integer.cuberoot(n))
    return root * root * root == n

def gcd(a: int, b: int): int
    # Greatest common divisor (Euclidean algorithm)
    a = abs(a)
    b = abs(b)
    
    while b != 0:
        t: int = b
        b = a % b
        a = t
    
    return a

def lcm(a: int, b: int): int
    # Least common multiple
    if a == 0 or b == 0:
        return 0
    return abs(a * b) / gcd(a, b)

def extendedGcd(a: int, b: int): tuple<int, int, int>
    # Returns (g, x, y) where g = gcd(a,b) = ax + by
    if a == 0:
        return b, 0, 1
    
    g: int
    x1: int
    y1: int
    g, x1, y1 = extendedGcd(b % a, a)
    
    x: int = y1 - (b / a) * x1
    y: int = x1
    
    return g, x, y

def inverseMod(a: int, m: int): int
    # Modular multiplicative inverse
    g: int
    x: int
    y: int
    g, x, y = extendedGcd(a, m)
    
    if g != 1:
        return 0  # No inverse exists
    
    return (x % m + m) % m

def powMod(base: int, exp: int, mod: int): int
    # Modular exponentiation
    result: int = 1
    base = base % mod
    
    while exp > 0:
        if exp % 2 == 1:
            result = (result * base) % mod
        exp = exp / 2
        base = (base * base) % mod
    
    return result

def factorial(n: int): int
    if n <= 1:
        return 1
    
    result: int = 1
    for i in range(2, n + 1):
        result = result * i
    
    return result

def fibonacci(n: int): int
    if n <= 1:
        return n
    
    a: int = 0
    b: int = 1
    
    for i in range(2, n + 1):
        c: int = a + b
        a = b
        b = c
    
    return b

def fibonacciLarge(n: int): BigInt
    if n <= 1:
        return BigInt(n)
    
    a: BigInt = BigInt(0)
    b: BigInt = BigInt(1)
    
    for i in range(2, n + 1):
        c: BigInt = a.add(b)
        a = b
        b = c
    
    return b

# =============================================================================
# NUMBER THEORY
# =============================================================================

def primeFactors(n: int): list<int>
    factors: list<int>
    
    while n % 2 == 0:
        factors.append(2)
        n = n / 2
    
    i: int = 3
    while i * i <= n:
        while n % i == 0:
            factors.append(i)
            n = n / i
        i = i + 2
    
    if n > 2:
        factors.append(n)
    
    return factors

def allDivisors(n: int): list<int>
    divisors: list<int> = []
    
    i: int = 1
    while i * i <= n:
        if n % i == 0:
            divisors.append(i)
            if i != n / i:
                divisors.append(n / i)
        i = i + 1
    
    divisors.sort()
    return divisors

def properDivisors(n: int): list<int>
    divs: list<int> = Integer.allDivisors(n)
    result: list<int> = []
    
    for d in divs:
        if d < n:
            result.append(d)
    
    return result

def divisorCount(n: int): int
    factors: list<int> = Integer.primeFactors(n)
    
    if len(factors) == 0:
        return 1
    
    uniqueFactors: list<int> = []
    for f in factors:
        if len(uniqueFactors) == 0 or uniqueFactors[-1] != f:
            uniqueFactors.append(f)
    
    result: int = 1
    count: int = 1
    
    for i in range(1, len(uniqueFactors)):
        if uniqueFactors[i] == uniqueFactors[i - 1]:
            count = count + 1
        else:
            result = result * (count + 1)
            count = 1
    
    result = result * (count + 1)
    return result

def divisorSum(n: int): int
    divs: list<int> = Integer.allDivisors(n)
    result: int = 0
    
    for d in divs:
        result = result + d
    
    return result

def eulerTotient(n: int): int
    result: int = n
    temp: int = n
    p: int = 2
    
    while p * p <= temp:
        if temp % p == 0:
            while temp % p == 0:
                temp = temp / p
            result = result / p * (p - 1)
        p = p + 1
    
    if temp > 1:
        result = result / temp * (temp - 1)
    
    return result

def mobius(n: int): int
    # Möbius function
    factors: list<int> = Integer.primeFactors(n)
    unique: list<int> = []
    
    for f in factors:
        if len(unique) == 0 or unique[-1] != f:
            unique.append(f)
    
    if len(unique) < len(factors):
        return 0  # Has squared prime factor
    
    if len(unique) % 2 == 0:
        return 1
    
    return -1

def liouville(n: int): int
    # Liouville function
    factors: list<int> = Integer.primeFactors(n)
    
    if len(factors) % 2 == 0:
        return 1
    
    return -1

def is Carmichael(n: int): bool
    # Carmichael function
    if n < 2:
        return False
    
    divs: list<int> = Integer.allDivisors(n)
    
    for d in divs:
        if d > 1 and n % (d - 1) != 0:
            return False
    
    return True

# =============================================================================
# PRIMALITY TESTING
# =============================================================================

def millerRabin(n: int, iterations: int = 10): bool
    if n < 2:
        return False
    if n == 2:
        return True
    if n % 2 == 0:
        return False
    
    if n < 2047:
        return isPrime(n)
    
    r: int = 0
    d: int = n - 1
    
    while d % 2 == 0:
        r = r + 1
        d = d / 2
    
    for i in range(iterations):
        a: int = Integer.randomInt(2, n - 2)
        x: int = powMod(a, d, n)
        
        if x == 1 or x == n - 1:
            continue
        
        for j in range(r - 1):
            x = powMod(x, 2, n)
            if x == n - 1:
                break
        else:
            return False
    
    return True

def isProbablePrime(n: int): bool
    return MillerRabin(n, 10)

# =============================================================================
# MODULAR ARITHMETIC
# =============================================================================

def modAdd(a: int, b: int, m: int): int
    return ((a % m) + (b % m)) % m

def modSub(a: int, b: int, m: int): int
    return ((a % m) - (b % m) + m) % m

def modMul(a: int, b: int, m: int): int
    return ((a % m) * (b % m)) % m

def modDiv(a: int, b: int, m: int): int
    inv: int = inverseMod(b, m)
    if inv == 0:
        return 0
    return (a % m) * inv % m

def modNeg(a: int, m: int): int
    return (m - (a % m)) % m

def modPow(base: int, exp: int, m: int): int
    return powMod(base, exp, m)

# =============================================================================
# CONVERSIONS
# =============================================================================

def toBinary(n: int): string
    if n == 0:
        return "0"
    
    result: string = ""
    sign: int = 1
    
    if n < 0:
        sign = -1
        n = -n
    
    while n > 0:
        result = str(n % 2) + result
        n = n / 2
    
    if sign < 0:
        result = "-" + result
    
    return result

def toOctal(n: int): string
    if n == 0:
        return "0"
    
    result: string = ""
    
    while n > 0:
        result = str(n % 8) + result
        n = n / 8
    
    return result

def toHex(n: int): string
    if n == 0:
        return "0"
    
    result: string = ""
    
    while n > 0:
        remainder: int = n % 16
        result = Integer.digitToChar(remainder) + result
        n = n / 16
    
    return result

def fromBinary(s: string): int
    result: int = 0
    
    for c in s:
        if c == '0' or c == '1':
            result = result * 2 + (c == '1')
    
    return result

def fromOctal(s: string): int
    result: int = 0
    
    for c in s:
        if c >= '0' and c <= '7':
            result = result * 8 + (ord(c) - ord('0'))
    
    return result

def fromHex(s: string): int
    result: int = 0
    
    for c in s:
        result = result * 16 + Integer.charToDigit(c)
    
    return result

def digitsToInt(digits: list<int>, base: int = 10): int
    result: int = 0
    
    for d in digits:
        result = result * base + d
    
    return result

def intToDigits(n: int, base: int = 10): list<int>
    digits: list<int>
    
    while n > 0:
        digits.append(n % base)
        n = n / base
    
    digits.reverse()
    return digits

# =============================================================================
# APPROXIMATION FUNCTIONS
# =============================================================================

def floorSqrt(n: int): int
    if n < 0:
        return 0
    
    if n < 2:
        return n
    
    x: int = n / 2
    y: int = (x + 1) / 2
    
    while y < x:
        x = y
        y = (x + n / x) / 2
    
    return x

def ceilSqrt(n: int): int
    result: int = floorSqrt(n)
    if result * result < n:
        result = result + 1
    return result

def floorCubeRoot(n: int): int
    if n >= 0:
        x: int = n / 3
        while x * x * x > n:
            x = (2 * x + n / (x * x)) / 3
    else:
        x = -((-n) / 3)
        while x * x * x > n:
            x = (2 * x + n / (x * x)) / 3
    
    return x

def ceilCubeRoot(n: int): int
    result: int = floorCubeRoot(n)
    if result * result * result < n:
        result = result + 1
    return result

def round(n: int): int
    return (n + (n % 2)) / 2

# =============================================================================
# UTILITY FUNCTIONS
# =============================================================================

def between(value: int, minVal: int, maxVal: int): bool
    return value >= minVal and value <= maxVal

def digitCount(n: int): int
    if n == 0:
        return 1
    
    count: int = 0
    n = abs(n)
    
    while n > 0:
        count = count + 1
        n = n / 10
    
    return count

def digitSum(n: int): int
    sum: int = 0
    n = abs(n)
    
    while n > 0:
        sum = sum + (n % 10)
        n = n / 10
    
    return sum

def digitProduct(n: int): int
    if n == 0:
        return 0
    
    product: int = 1
    n = abs(n)
    
    while n > 0:
        d: int = n % 10
        if d != 0:
            product = product * d
        n = n / 10
    
    return product

def reverseDigits(n: int): int
    result: int = 0
    n = abs(n)
    
    while n > 0:
        result = result * 10 + (n % 10)
        n = n / 10
    
    return result

def rotateDigits(n: int, k: int): int
    # Rotate digits by k positions
    s: string = str(abs(n))
    k = k % len(s)
    
    if k < 0:
        k = k + len(s)
    
    if k == 0:
        return n
    
    rotated: string = s[-k:] + s[:-k]
    result: int = Integer.fromBinary(rotated)
    
    return -result if n < 0 else result

def palindromeNumber(n: int): bool
    return n == reverseDigits(n)

def happyNumber(n: int): bool
    # Happy number check (iterates sum of squares of digits)
    seen: list<int> = []
    
    while n != 1 and n not in seen:
        seen.append(n)
        n = digitSumPow(n, 2)
    
    return n == 1

def digitSumPow(n: int, power: int): int
    sum: int = 0
    
    while n > 0:
        d: int = n % 10
        sum = sum + d * d * power if power > 1 else d * d
        n = n / 10
    
    return sum

def floorLog2(n: int): int
    if n <= 0:
        return 0
    
    result: int = 0
    
    while n > 0:
        result = result + 1
        n = n >> 1
    
    return result - 1

def ceilLog2(n: int): int
    return floorLog2(n - 1) + 1

