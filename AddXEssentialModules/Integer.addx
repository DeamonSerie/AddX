# =============================================================================
# CONVENIENCE FUNCTIONS
# =============================================================================

def randomPrime(bits: int = 32): int
    while True:
        n: int = Integer.randomInt(1 << (bits - 1), 1 << bits)
        if isPrime(n):
            return n

def randomOdd(bits: int = 32): int
    result: int = Integer.randomInt(1 << (bits - 1), 1 << bits)
    
    while result % 2 == 0:
        result = Integer.randomInt(1 << (bits - 1), 1 << bits)
    
    return result

def randomCoprime(n: int): int
    while True:
        r: int = Integer.randomInt(2, n - 1)
        if gcd(r, n) == 1:
            return r

# Private helper functions for BigInt
def multiplyBase(value: int, base: int): list<int>
    result: list<int>
    carry: int = 0
    
    for d in value:
        current: int = d * base + carry
        result.append(current % 1000000000)
        carry = current / 1000000000
    
    while carry > 0:
        result.append(carry % 1000000000)
        carry = carry / 1000000000
    
    return result

def charToDigit(c: string): int
    code: int = ord(c)
    if code >= 48 and code <= 57:
        return code - 48
    if code >= 65 and code <= 90:
        return code - 55
    if code >= 97 and code <= 122:
        return code - 87
    return 0

def digitToChar(d: int): string
    if d < 10:
        return chr(48 + d)
    return chr(55 + d)

def removeLeadingZeros(arr: list<int>)
    while len(arr) > 0 and arr[-1] == 0:
        arr.pop()

def bitWidth(n: int): int
    if n <= 0:
        return 0
    return floorLog2(n) + 1