import PyCompat

# === Integer ===

# =============================================================================
# BIG INTEGER
# =============================================================================

class BigInt
    sign: int
    digits: list<int>  # Base 1,000,000,000 (1e9)
    
    def init(value: int = 0)
        if value < 0:
            this.sign = -1
            value = -value
        else:
            this.sign = 1
        
        this.digits = []
        
        while value > 0:
            this.digits.append(value % 1000000000)
            value = value / 1000000000
    
    def initString(value: string, base: int = 10)
        this.sign = 1
        this.digits = []
        
        for c in value:
            digit: int = Integer.charToDigit(c)
            this.multiplyBaseAdd(digit, base)
    
    def fromString(value: string): BigInt
        return Integer.BigInt.initString(value)
    
    def toString(base: int = 10): string
        if this.isZero():
            return "0"
        
        result: string = ""
        temp: list<int> = this.digits.copy()
        tempSign: int = this.sign
        
        while not this.isZero():
            remainder: int = 0
            for i in range(len(temp) - 1, -1, -1):
                current: int = remainder * 1000000000 + temp[i]
                temp[i] = current / base
                remainder = current % base
            
            result = Integer.digitToChar(remainder) + result
            this.removeLeadingZeros(temp)
        
        if tempSign < 0:
            result = "-" + result
        
        return result
    
    def isZero(): bool
        return len(this.digits) == 0
    
    def isNegative(): bool
        return this.sign < 0
    
    def isPositive(): bool
        return this.sign > 0 and not this.isZero()
    
    def compare(other: BigInt): int
        if len(this.digits) != len(other.digits):
            if len(this.digits) < len(other.digits):
                return -1
            return 1
        
        for i in range(len(this.digits) - 1, -1, -1):
            if this.digits[i] != other.digits[i]:
                if this.digits[i] < other.digits[i]:
                    return -1
                return 1
        
        return 0
    
    def abs(): BigInt
        result: BigInt = BigInt()
        result.digits = this.digits.copy()
        result.sign = 1
        return result
    
    def negate(): BigInt
        result: BigInt = BigInt()
        result.digits = this.digits.copy()
        result.sign = -this.sign
        return result
    
    def add(other: BigInt): BigInt
        if other.isZero():
            return this
        
        if this.isZero():
            return other
        
        result: BigInt = BigInt()
        
        if this.sign == other.sign:
            result.sign = this.sign
            result.digits = this.addDigits(this.digits, other.digits)
        else:
            cmp: int = this.abs().compare(other.abs())
            if cmp == 0:
                return result
            
            if cmp > 0:
                result.sign = this.sign
                result.digits = this.subtractDigits(this.digits, other.digits)
            else:
                result.sign = other.sign
                result.digits = this.subtractDigits(other.digits, this.digits)
        
        return result
    
    def subtract(other: BigInt): BigInt
        return this.add(other.negate())
    
    def multiply(other: BigInt): BigInt
        if this.isZero() or other.isZero():
            return BigInt()
        
        result: BigInt = BigInt()
        result.sign = this.sign * other.sign
        
        for i in range(len(this.digits)):
            for j in range(len(other.digits)):
                product: int = this.digits[i] * other.digits[j]
                result.digits = result.addSingleDigit(product, i + j)
        
        result.normalize()
        return result
    
    def divide(other: BigInt): tuple<BigInt, BigInt>
        # Returns (quotient, remainder)
        quotient: BigInt = BigInt()
        remainder: BigInt = BigInt()
        
        if other.isZero():
            # Division by zero error
            return quotient, remainder
        
        if this.abs().compare(other.abs()) < 0:
            return quotient, this.abs()
        
        dividend: BigInt = this.abs()
        divisor: BigInt = other.abs()
        
        while dividend.compare(divisor) >= 0:
            shift: int = dividend.bitLength() - divisor.bitLength()
            if shift < 0:
                shift = 0
            
            shifted: BigInt = divisor << shift
            shifted.sign = 1
            
            while dividend.compare(shifted) >= 0:
                quotient.digits = quotient.addSingleDigit(1 << shift)
                dividend = dividend.subtract(shifted)
        
        quotient.sign = this.sign * other.sign
        remainder = dividend
    
    def mod(other: BigInt): BigInt
        q: BigInt
        r: BigInt
        q, r = this.divide(other)
        return r
    
    def pow(exponent: int): BigInt
        result: BigInt = BigInt(1)
        base: BigInt = this.copy()
        
        while exponent > 0:
            if exponent % 2 == 1:
                result = result.multiply(base)
            base = base.multiply(base)
            exponent = exponent / 2
        
        return result
    
    def bitLength(): int
        if this.isZero():
            return 0
        
        mostSignificant: int = this.digits[-1]
        bits: int = 0
        
        while mostSignificant > 0:
            bits = bits + 1
            mostSignificant = mostMinimum >> 1
        
        return bits + (len(this.digits) - 1) * 30
    
    def copy(): BigInt
        result: BigInt = BigInt()
        result.sign = this.sign
        result.digits = this.digits.copy()
        return result
    
    def addDigits(a: list<int>, b: list<int>): list<int>
        result: list<int>
        carry: int = 0
        maxLen: int = Math.max(len(a), len(b))
        
        for i in range(maxLen):
            sum: int = carry
            if i < len(a):
                sum = sum + a[i]
            if i < len(b):
                sum = sum + b[i]
            
            result.append(sum % 1000000000)
            carry = sum / 1000000000
        
        if carry > 0:
            result.append(carry)
        
        return result
    
    def subtractDigits(a: list<int>, b: list<int>): list<int>
        result: list<int>
        borrow: int = 0
        
        for i in range(len(a)):
            diff: int = a[i] - borrow
            if i < len(b):
                diff = diff - b[i]
            
            if diff < 0:
                diff = diff + 1000000000
                borrow = 1
            else:
                borrow = 0
            
            result.append(diff)
        
        return result
    
    def addSingleDigit(value: int, position: int)
        while position >= len(this.digits):
            this.digits.append(0)
        
        this.digits[position] = this.digits[position] + value
        carry: int = this.digits[position] / 1000000000
        this.digits[position] = this.digits[position] % 1000000000
        
        while carry > 0:
            position = position + 1
            if position >= len(this.digits):
                this.digits.append(0)
            
            this.digits[position] = this.digits[position] + carry
            carry = this.digits[position] / 1000000000
            this.digits[position] = this.digits[position] % 1000000000
    
    def multiplyBaseAdd(digit: int, base: int)
        carry: int = digit
        
        for i in range(len(this.digits)):
            current: int = this.digits[i] * base + carry
            this.digits[i] = current % 1000000000
            carry = current / 1000000000
        
        while carry > 0:
            this.digits.append(carry % 1000000000)
            carry = carry / 1000000000
    
    def removeLeadingZeros(arr: list<int>)
        while len(arr) > 0 and arr[-1] == 0:
            arr.pop()
    
    def normalize()
        this.removeLeadingZeros(this.digits)

