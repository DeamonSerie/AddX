def hashFile(path: string, algorithm: string = "sha256"): string
    pass

def hashFiles(paths: list<string>, algorithm: string = "sha256"): list<string>
    results: list<string>
    for path in paths:
        results.append(Crypto.hashFile(path, algorithm))
    return results

