# =============================================================================
# CONVENIENCE FUNCTIONS
# =============================================================================

def encryptAesEcb(plaintext: string, key: string): string
    cipher: Crypto.AES = Crypto.AES(key, Crypto.MODE_ECB)
    return cipher.encrypt(plaintext)

def decryptAesEcb(ciphertext: string, key: string): string
    cipher: Crypto.AES = Crypto.AES(key, Crypto.MODE_ECB)
    return cipher.decrypt(ciphertext)

def encryptAesCbc(plaintext: string, key: string): string
    cipher: Crypto.AES = Crypto.AES(key, Crypto.MODE_CBC)
    return cipher.encrypt(plaintext)

def decryptAesCbc(ciphertext: string, key: string): string
    cipher: Crypto.AES = Crypto.AES(key, Crypto.MODE_CBC)
    return cipher.decrypt(ciphertext)

def hashPassword(password: string, cost: int = 10): string
    # Hash password for storage
    return Crypto.bcrypt(password, cost)

def verifyPassword(password: string, hash: string): bool
    return Crypto.bcryptVerify(password, hash)

def encryptPassword(password: string): string
    # Convenience for hashing passwords
    return Crypto.hashPassword(password)

def createKeyPair(): tuple<string, string>
    # Generate new key pair
    return Crypto.RSA(2048).generateKeyPair()

def createEccKeyPair(): tuple<string, string>
    return Crypto.ECC().generateKeyPair()

def createEd25519KeyPair(): tuple<string, string>
    return Crypto.Ed25519().generateKeyPair()

# =============================================================================
# DEBUGGING / DEVELOPMENT
# =============================================================================

def hexDump(data: string, width: int = 16): string
    # Create hexadecimal dump
    lines: list<string>
    
    for i in range(0, len(data), width):
        chunk: string = data[i:Math.min(i + width, len(data))]
        hexPart: string = Crypto.hexEncode(chunk)
        asciiPart: string = ""
        
        for j in range(len(chunk)):
            code: int = ord(chunk[j])
            if code >= 32 and code < 127:
                asciiPart = asciiPart + chr(code)
            else:
                asciiPart = asciiPart + "."
        
        lines.append(f"{i:04x}: {hexPart:<{width * 2}} {asciiPart}")
    
    return "\n".join(lines)

def isValidHex(data: string): bool
    for c in data:
        if not ((c >= '0' and c <= '9') or (c >= 'a' and c <= 'f') or (c >= 'A' and c <= 'F')):
            return False
    return True

def isValidBase64(data: string): bool
    for c in data:
        if not ((c >= 'A' and c <= 'Z') or (c >= 'a' and c <= 'z') or (c >= '0' and c <= '9') or c == '+' or c == '/' or c == '='):
            return False
    return True

def charToNibble(c: string): int
    code: int = ord(c)
    if c >= '0' and c <= '9':
        return code - ord('0')
    if c >= 'a' and c <= 'f':
        return code - ord('a') + 10
    if c >= 'A' and c <= 'F':
        return code - ord('A') + 10
    return 0

def nibbleToChar(n: int): string
    if n < 10:
        return chr(ord('0') + n)
    return chr(ord('a') + n - 10)

# =============================================================================
# EXAMPLES
# =============================================================================

def examples()
    # Simple hashing
    hashed: string = Crypto.hash_sha256("Hello, World!")
    
    # Password hashing
    passwordHash: string = Crypto.hashPassword("my_secure_password")
    isValid: bool = Crypto.verifyPassword("my_secure_password", passwordHash)
    
    # Encryption
    key: string = Crypto.randomBytes(32)
    plaintext: string = "Secret message"
    ciphertext: string = Crypto.encryptAesCbc(plaintext, key)
    decrypted: string = Crypto.decryptAesCbc(ciphertext, key)
    
    # Key generation
    publicKey: string
    privateKey: string
    publicKey, privateKey = Crypto.RSA(2048).generateKeyPair()
    
    # Base encoding
    encoded: string = Crypto.base64Encode("Hello")
    decoded: string = Crypto.base64Decode(encoded)
    
    print("Examples complete")