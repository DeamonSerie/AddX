def generateKeyPair(algorithm: string = "rsa", keySize: int = 2048): tuple<string, string>
    result: tuple<string, string>
    
    if algorithm == "rsa":
        rsa: Crypto.RSA = Crypto.RSA(keySize)
        result = rsa.generateKeyPair()
    else if algorithm == "ecc":
        ecc: Crypto.ECC = Crypto.ECC()
        result = ecc.generateKeyPair()
    else if algorithm == "ed25519":
        ed: Crypto.Ed25519 = Crypto.Ed25519()
        result = ed.generateKeyPair()
    
    return result

