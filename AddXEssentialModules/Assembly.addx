# =============================================================================
# MACROS
# =============================================================================

def PUSHAD()
    # Push all general registers
    "push rax; push rcx; push rdx; push rbx; push rsp; push rbp; push rsi; push rdi"

def POPAD()
    # Pop all general registers
    "pop rdi; pop rsi; pop rbp; pop rsp; pop rbx; pop rdx; pop rcx; pop rax"

def PUSHFD()
    # Push all flags
    "pushf"

def POPFD()
    # Pop all flags  
    "popf"

def ENTER(size: Imm, nesting: Imm)
    # Enter procedure (setup stack frame)
    "push rbp; mov rbp, rsp; sub rsp, size"

def LEAVE()
    # Leave procedure (restore stack frame)
    "mov rsp, rbp; pop rbp"

def CALL(label: Label)
    "push pc; jmp label"

def PUSHIMM(imm: Imm)
    "mov rax, imm; push rax"

def JMP_SHORT(label: Label)
    "jmp short label"

def JMP_NEAR(label: Label)
    "jmp near label"

# =============================================================================
# EXAMPLE PROGRAMS
# =============================================================================

def exampleAdd()
    # Simple addition example
    labels:
        start
    
    main:
        MOVI(RAX, 5)
        MOVI(RCX, 3)
        ADD(RAX, RCX)
        RET

def exampleLoop()
    # Loop counting down
    labels:
        start
    
    main:
        MOVI(RAX, 10)
        MOVI(RCX, 0)
    
    loop:
        INC(RCX)
        DEC(RAX)
        JNZ(loop)
        RET

def exampleFunctionCall()
    # Function call example
    labels:
        main
        add_numbers
    
    main:
        CALL(add_numbers)
        RET
    
    add_numbers:
        ENTER(0, 0)
        PUSHIMM(5)
        POP(RAX)
        ADD(RAX, 3)
        LEAVE()
        RET

def exampleConditional()
    # Conditional example
    labels:
        main
    
    main:
        MOVI(RAX, 10)
        CMP(RAX, 5)
        JA(greater)
        MOVI(RAX, 0)
        JMP(done)
    
    greater:
        MOVI(RAX, 1)
    
    done:
        RET